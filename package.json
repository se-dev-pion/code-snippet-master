{
  "name": "code-snippet-master",
  "displayName": "Code Snippet Master",
  "description": "A better experience for snippets management instead of native ones",
  "version": "0.1.0",
  "icon": "./assets/icon.png",
  "publisher": "se-dev-pion",
  "repository": "https://github.com/se-dev-pion/code-snippet-master",
  "engines": {
    "vscode": "^1.100.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "code-snippet-master.load-config",
        "title": "Load",
        "icon": "$(add)"
      },
      {
        "command": "code-snippet-master.unload-config",
        "title": "Unload",
        "icon": "$(trash)"
      },
      {
        "command": "code-snippet-master.force-sync",
        "title": "Force Sync",
        "icon": "$(sync)"
      },
      {
        "command": "code-snippet-master.reload-config",
        "title": "Reload",
        "icon": "$(refresh)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "code-snippet-master.load-config",
          "when": "view == code-snippet-master.loaded-configs",
          "group": "navigation"
        },
        {
          "command": "code-snippet-master.force-sync",
          "when": "view == code-snippet-master.loaded-configs",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "code-snippet-master.unload-config",
          "when": "view == code-snippet-master.loaded-configs",
          "group": "inline"
        },
        {
          "command": "code-snippet-master.reload-config",
          "when": "view == code-snippet-master.loaded-configs",
          "group": "inline"
        }
      ]
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "code-snippet-master",
          "title": "Code Snippet Master",
          "icon": "assets/sidebar.png"
        }
      ]
    },
    "views": {
      "code-snippet-master": [
        {
          "id": "code-snippet-master.loaded-configs",
          "name": "Loaded Configs",
          "icon": "assets/sidebar.png"
        }
      ]
    },
    "languages": [
      {
        "id": "snippet",
        "aliases": [
          "Snippet"
        ],
        "extensions": [
          ".snippet.xml"
        ],
        "icon": {
          "light": "./assets/light.png",
          "dark": "./assets/dark.png"
        }
      }
    ],
    "grammars": [
      {
        "language": "snippet",
        "scopeName": "source.snippet",
        "path": "./syntaxes/snippet.tmLanguage.json"
      },
      {
        "scopeName": "snippet.injection",
        "path": "./syntaxes/embed.tmLanguage.json",
        "injectTo": [
          "source.snippet"
        ]
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "pnpm run package",
    "compile": "pnpm run check-types && pnpm run lint && node esbuild.js",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "pnpm run check-types && pnpm run lint && node esbuild.js --production",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "pnpm run compile-tests && pnpm run compile && pnpm run lint",
    "check-types": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vscode-test",
    "build": "vsce package --no-dependencies",
    "publish": "vsce publish --no-dependencies",
    "preview": "vsce publish --pre-release --no-dependencies"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/vscode": "^1.100.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "@vscode/vsce": "^3.7.1",
    "esbuild": "^0.27.2",
    "eslint": "^9.39.2",
    "eslint-plugin-neverthrow": "^1.1.4",
    "npm-run-all": "^4.1.5",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.54.0"
  },
  "dependencies": {
    "fast-xml-parser": "^5.3.7",
    "neverthrow": "^8.2.0",
    "zod": "^4.3.6"
  }
}